flowchart LR
    U["Оператор банка"] -->|"логин, пароль, команды CRUD / перевод / фильтр"| P1["1.0 Оконный клиент"]
    P1 -->|"HTTP JSON-запрос + bearer-токен"| P2["2.0 API сервер"]
    P2 -->|"DTO, ошибки валидации, статусы операций"| P1

    P2 -->|"учетные данные"| P3["3.0 Авторизация"]
    P3 -->|"поиск пользователя"| D1[("D1 Users")]
    D1 -->|"роль, соль и хеш пароля"| P3
    P3 -->|"bearer-токен / отказ"| P2

    P2 -->|"запрос операции + mode=sql/orm"| P4["4.0 CRUD, поиск и перевод"]
    P4 -->|"создание/изменение/удаление клиента"| D2[("D2 Customers")]
    D2 -->|"найденные клиенты"| P4
    P4 -->|"чтение/запись счетов, изменение баланса"| D3[("D3 Accounts")]
    D3 -->|"балансы и номера счетов"| P4
    P4 -->|"получение комиссии"| D4[("D4 PartnerBanks")]
    D4 -->|"банк-партнер и процент комиссии"| P4
    P4 -->|"запись истории перевода"| D5[("D5 Transactions")]
    D5 -->|"история операций"| P4
    P4 -->|"результат операции"| P2
